  const lines=[
    ['CARTOTECNICA — Preventivo materiale'],
    ['Data', new Date().toLocaleString('it-IT')],
    ['Modello', document.getElementById('activeModelName').textContent.replace(/—/g,'').trim()],
    [],
    ['Cartelle da produrre', d.qty],
    [],
    ['MATERIALE','QUANTITÀ','NOTE'],
    ['Fogli cartone', d.fogli_cartone, `${v('foglio_cartone_l')}x${v('foglio_cartone_h')} cm`],
    ['Tela (metri)', d.m_tela_tot.toFixed(2), `${d.rotoli_tela} rotoli da ${v('tela_lung')} m`],
    ['Fogli carta', d.fogli_carta_tot, `${v('foglio_carta_l')}x${v('foglio_carta_h')} cm`],
    ['Fettuccia (metri)', d.m_fettuccia.toFixed(2), `${d.bobine} bobine da ${v('fettuccia_bob')} m`],
    [],
    ['DETTAGLIO PEZZI'],
    ['Piatti cartone', d.qty*2],
    ['Dorsi cartone', d.qty],
    ['Dorso tela', d.dt_tot],
    ['Patte piccole tela', d.pp_tot],
    ['Patte grandi tela', d.pg_tot],
    ['Piatti esterni carta', d.cpe_tot],
    ['Piatti interni carta', d.cpi_tot],
    ['Dorso carta', d.cd_tot],
    ['Carta patte piccole', d.cpp_tot],
