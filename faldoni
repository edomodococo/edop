<script>
/* ============================================================
   STORAGE — wrapper localStorage (browser nativo)
   ============================================================ */
const STORAGE_PREFIX = 'cartotecnica_modello_';
const storage = {
  list(){
    const keys=[];
    for(let i=0;i<localStorage.length;i++){
      const k=localStorage.key(i);
      if(k && k.startsWith(STORAGE_PREFIX)) keys.push(k);
    }
    return keys;
  },
  get(k){ return localStorage.getItem(k); },
  set(k,v){ localStorage.setItem(k,v); },
  delete(k){ localStorage.removeItem(k); }
};

/* ============================================================
   CAMPI
   ============================================================ */
const FIELDS = [
  'piatto_l','piatto_h','dorso_l',
  'foglio_cartone_l','foglio_cartone_h','foglio_carta_l','foglio_carta_h',
  'tela_h','tela_lung','fettuccia_bob',
  'dt_l','dt_h','dt_q','pp_l','pp_h','pp_q','pg_l','pg_h','pg_q',
  'cpe_l','cpe_h','cpe_q','cpi_l','cpi_h','cpi_q','cd_l','cd_h','cd_q',
  'cpp_l','cpp_h','cpp_q','cpg_l','cpg_h','cpg_q',
  'fd_q','fd_l','fc_q','fc_l','fp_q','fp_l'
];

function v(id){ return parseFloat(document.getElementById(id).value) || 0; }

/* ============================================================
   PEZZI PER FOGLIO
   ============================================================ */
function pezziPerFoglio(W,H,w,h){
  if(w<=0||h<=0) return {n:0,cols:0,rows:0,rot:false,used_w:0,used_h:0,pw:0,ph:0};
  const a_cols=Math.floor(W/w), a_rows=Math.floor(H/h), a=a_cols*a_rows;
  const b_cols=Math.floor(W/h), b_rows=Math.floor(H/w), b=b_cols*b_rows;
  if(b>a) return {n:b,cols:b_cols,rows:b_rows,rot:true,used_w:b_cols*h,used_h:b_rows*w,pw:h,ph:w};
  return {n:a,cols:a_cols,rows:a_rows,rot:false,used_w:a_cols*w,used_h:a_rows*h,pw:w,ph:h};
}

function disegna(svgId, W, H, pieces){
  const svg = document.getElementById(svgId);
  if(!svg) return;
  svg.setAttribute('viewBox',`0 0 ${W} ${H}`);
  let s = `<rect x="0" y="0" width="${W}" height="${H}" fill="#fff" stroke="#1a1410" stroke-width="0.4"/>`;
  pieces.forEach(p=>{
    s += `<rect x="${p.x}" y="${p.y}" width="${p.w}" height="${p.h}" fill="${p.color}" stroke="#1a1410" stroke-width="0.25" opacity="0.85"/>`;
    if(p.label && p.w>6 && p.h>4){
      s += `<text x="${p.x+p.w/2}" y="${p.y+p.h/2}" font-family="JetBrains Mono" font-size="${Math.min(p.w,p.h)/5}" fill="#1a1410" text-anchor="middle" dominant-baseline="central" font-weight="600">${p.label}</text>`;
    }
  });
  svg.innerHTML = s;
}

function gridPieces(W,H,res,color,labelPrefix){
  const out=[];
  let i=1;
  for(let r=0;r<res.rows;r++){
    for(let c=0;c<res.cols;c++){
      out.push({
        x:c*res.pw, y:r*res.ph,
        w:res.pw, h:res.ph,
        color:color, label:`${labelPrefix}${i++}`
      });
    }
  }
  return out;
}

/* ============================================================
   LAYOUT CARTONE
   ============================================================ */
function layoutCartone(){
  const W=v('foglio_cartone_l'), H=v('foglio_cartone_h');
  const pw=v('piatto_l'), ph=v('piatto_h');
  const dw=v('dorso_l'), dh=v('piatto_h');

  const tryConfig = (pW,pH, dW,dH)=>{
    const cols=Math.floor(W/pW), rows=Math.floor(H/pH);
    const piatti = cols*rows;
    const used_w = cols*pW, used_h=rows*pH;
    const rem_w = W - used_w;
    const rem_h_bottom = H - used_h;

    let dorsi=0;
    const pieces=[];

    for(let r=0;r<rows;r++)for(let c=0;c<cols;c++){
      pieces.push({x:c*pW,y:r*pH,w:pW,h:pH,color:'#d9a48a',label:'P'});
    }

    const tryDorsoArea = (areaW, areaH, ox, oy)=>{
      const a_cols=Math.floor(areaW/dW), a_rows=Math.floor(areaH/dH);
      const b_cols=Math.floor(areaW/dH), b_rows=Math.floor(areaH/dW);
      if(b_cols*b_rows > a_cols*a_rows){
        const n=b_cols*b_rows; const ps=[];
        for(let r=0;r<b_rows;r++)for(let c=0;c<b_cols;c++){
          ps.push({x:ox+c*dH, y:oy+r*dW, w:dH, h:dW, color:'#b8341a', label:'D'});
        }
        return {n, pieces:ps};
      }
      const n=a_cols*a_rows; const ps=[];
      for(let r=0;r<a_rows;r++)for(let c=0;c<a_cols;c++){
        ps.push({x:ox+c*dW, y:oy+r*dH, w:dW, h:dH, color:'#b8341a', label:'D'});
      }
      return {n, pieces:ps};
    };

    const right = tryDorsoArea(rem_w, used_h, used_w, 0);
    const bottom = tryDorsoArea(W, rem_h_bottom, 0, used_h);

    dorsi = right.n + bottom.n;
    pieces.push(...right.pieces, ...bottom.pieces);

    return {piatti, dorsi, pieces};
  };

  const c1 = tryConfig(pw,ph,dw,dh);
  const c2 = tryConfig(ph,pw,dw,dh);
  const score = c=> c.piatti*1000 + c.dorsi;
  const best = score(c1) >= score(c2) ? c1 : c2;

  disegna('svg_cartone', W, H, best.pieces);

  const cartelle_da_foglio = Math.min(Math.floor(best.piatti/2), best.dorsi);

  document.getElementById('info_cartone').innerHTML = `
    <div class="list">
      <div class="row"><div class="k">Piatti per foglio<small>${v('piatto_l')}×${v('piatto_h')} cm</small></div><div class="v">${best.piatti} pz</div></div>
      <div class="row"><div class="k">Dorsi per foglio<small>${v('dorso_l')}×${v('piatto_h')} cm</small></div><div class="v">${best.dorsi} pz</div></div>
      <div class="row total"><div class="k">Cartelle complete da 1 foglio<small>2 piatti + 1 dorso ciascuna</small></div><div class="v">${cartelle_da_foglio} cart.</div></div>
    </div>`;

  return {piatti_per_foglio: best.piatti, dorsi_per_foglio: best.dorsi, cartelle_per_foglio: cartelle_da_foglio};
}

/* ============================================================
   LAYOUT TELA
   ============================================================ */
function layoutTela(){
  const altezzaRotolo = v('tela_h');

  const dt_l=v('dt_l'), dt_h=v('dt_h');
  const dt = pezziPerFoglio(altezzaRotolo, dt_h, dt_l, dt_h);
  disegnaFascia('svg_tela_dt', altezzaRotolo, dt_h, dt, '#b8341a','DT');
  document.getElementById('info_tela_dt').innerHTML = fasciaInfo('Dorso tela', dt_l, dt_h, altezzaRotolo, dt);

  const pp_l=v('pp_l'), pp_h=v('pp_h');
  const pp = pezziPerFoglio(altezzaRotolo, pp_h, pp_l, pp_h);
  disegnaFascia('svg_tela_pp', altezzaRotolo, pp_h, pp, '#d9a48a','PP');
  document.getElementById('info_tela_pp').innerHTML = fasciaInfo('Patta piccola', pp_l, pp_h, altezzaRotolo, pp);

  const pg_l=v('pg_l'), pg_h=v('pg_h');
  const pg = pezziPerFoglio(altezzaRotolo, pg_h, pg_l, pg_h);
  disegnaFascia('svg_tela_pg', altezzaRotolo, pg_h, pg, '#3a6b3a','PG');
  document.getElementById('info_tela_pg').innerHTML = fasciaInfo('Patta grande', pg_l, pg_h, altezzaRotolo, pg);

  return {
    dt_per_fascia: dt.n, dt_altezza_fascia: dt_h,
    pp_per_fascia: pp.n, pp_altezza_fascia: pp_h,
    pg_per_fascia: pg.n, pg_altezza_fascia: pg_h
  };
}
function disegnaFascia(id, W, H, res, color, lab){
  const svg=document.getElementById(id);
  svg.setAttribute('viewBox',`0 0 ${W} ${H}`);
  let s=`<rect x="0" y="0" width="${W}" height="${H}" fill="#fff" stroke="#1a1410" stroke-width="0.3"/>`;
  for(let c=0;c<res.cols;c++)for(let r=0;r<res.rows;r++){
    s+=`<rect x="${c*res.pw}" y="${r*res.ph}" width="${res.pw}" height="${res.ph}" fill="${color}" stroke="#1a1410" stroke-width="0.2" opacity="0.85"/>`;
    s+=`<text x="${c*res.pw+res.pw/2}" y="${r*res.ph+res.ph/2}" font-family="JetBrains Mono" font-size="${Math.min(res.pw,res.ph)/4}" fill="#1a1410" text-anchor="middle" dominant-baseline="central" font-weight="600">${lab}</text>`;
  }
  svg.innerHTML=s;
}
function fasciaInfo(name, pl, ph, altezzaRotolo, res){
  const consumo_m = (ph/100).toFixed(3);
  const sfrido_w = altezzaRotolo - res.cols*res.pw;
  return `<div class="list">
    <div class="row"><div class="k">${name}<small>${pl}×${ph} cm · fascia ${altezzaRotolo}×${ph} cm</small></div><div class="v">${res.n} pz/fascia</div></div>
    <div class="row"><div class="k">Tela consumata per fascia<small>lineare</small></div><div class="v">${consumo_m} m</div></div>
    <div class="row"><div class="k">Sfrido laterale fascia<small>larghezza non utilizzata</small></div><div class="v">${sfrido_w.toFixed(1)} cm</div></div>
  </div>`;
}

/* ============================================================
   LAYOUT CARTA
   ============================================================ */
function layoutCarta(){
  const W=v('foglio_carta_l'), H=v('foglio_carta_h');
  const tipi=[
    {key:'pe', l:v('cpe_l'),h:v('cpe_h'), color:'#d9a48a', lab:'PE'},
    {key:'pi', l:v('cpi_l'),h:v('cpi_h'), color:'#b8341a', lab:'PI'},
    {key:'pp', l:v('cpp_l'),h:v('cpp_h'), color:'#3a6b3a', lab:'PP'},
    {key:'pg', l:v('cpg_l'),h:v('cpg_h'), color:'#a86a1f', lab:'PG'}
  ];
  const out={};
  tipi.forEach(t=>{
    const res=pezziPerFoglio(W,H,t.l,t.h);
    const pieces=gridPieces(W,H,res,t.color,t.lab+'-');
    disegna('svg_carta_'+t.key, W, H, pieces);
    const sfridoX=W-res.cols*res.pw, sfridoY=H-res.rows*res.ph;
    document.getElementById('info_carta_'+t.key).innerHTML=`
      <div class="list">
        <div class="row"><div class="k">Pezzi per foglio<small>${t.l}×${t.h} cm ${res.rot?'(ruotati)':''}</small></div><div class="v">${res.n} pz</div></div>
        <div class="row"><div class="k">Sfrido X / Y<small>cm non utilizzati</small></div><div class="v">${sfridoX.toFixed(1)} / ${sfridoY.toFixed(1)}</div></div>
      </div>`;
    out[t.key]=res.n;
  });
  return out;
}

function fettucciaPerCartella(){
  const tot_d = v('fd_q')*v('fd_l');
  const tot_c = v('fc_q')*v('fc_l');
  const tot_p = v('fp_q')*v('fp_l');
  document.getElementById('fd_tot').textContent = tot_d.toFixed(1) + ' cm';
  document.getElementById('fc_tot').textContent = tot_c.toFixed(1) + ' cm';
  document.getElementById('fp_tot').textContent = tot_p.toFixed(1) + ' cm';
  return {tot_dorso:tot_d, tot_cartella:tot_c, tot_patta:tot_p, tot_complessivo: tot_d+tot_c+tot_p};
}

/* ============================================================
   PRODUZIONE
   ============================================================ */
function aggiornaProduzione(){
  const qty=Math.max(1, parseInt(document.getElementById('qty_cartelle').value||'1',10));

  const cart = layoutCartone();
  const piatti_tot = qty*2, dorsi_tot = qty*1;
  const fogli_per_piatti = Math.ceil(piatti_tot/Math.max(cart.piatti_per_foglio,1));
  const fogli_per_dorsi = Math.ceil(dorsi_tot/Math.max(cart.dorsi_per_foglio,1));
  const fogli_cartone = Math.max(fogli_per_piatti, fogli_per_dorsi);
  const piatti_ottenibili = fogli_cartone*cart.piatti_per_foglio;
  const dorsi_ottenibili = fogli_cartone*cart.dorsi_per_foglio;
  const sfr_piatti = piatti_ottenibili - piatti_tot;
  const sfr_dorsi = dorsi_ottenibili - dorsi_tot;

  const tela = layoutTela();
  const dt_tot = qty*v('dt_q');
  const pp_tot = qty*v('pp_q');
  const pg_tot = qty*v('pg_q');
  const fasce_dt = Math.ceil(dt_tot/Math.max(tela.dt_per_fascia,1));
  const fasce_pp = Math.ceil(pp_tot/Math.max(tela.pp_per_fascia,1));
  const fasce_pg = Math.ceil(pg_tot/Math.max(tela.pg_per_fascia,1));
  const m_dt = fasce_dt * tela.dt_altezza_fascia / 100;
  const m_pp = fasce_pp * tela.pp_altezza_fascia / 100;
  const m_pg = fasce_pg * tela.pg_altezza_fascia / 100;
  const m_tela_tot = m_dt + m_pp + m_pg;
  const rotoli_tela = Math.ceil(m_tela_tot / Math.max(v('tela_lung'),1));
  const tela_residua = rotoli_tela*v('tela_lung') - m_tela_tot;

  const carta = layoutCarta();
  const cpe_tot=qty*v('cpe_q'), cpi_tot=qty*v('cpi_q'), cd_tot=qty*v('cd_q'), cpp_tot=qty*v('cpp_q'), cpg_tot=qty*v('cpg_q');
  const f_cpe=Math.ceil(cpe_tot/Math.max(carta.pe,1));
  const f_cpi=Math.ceil(cpi_tot/Math.max(carta.pi,1));
  const f_cpp=Math.ceil(cpp_tot/Math.max(carta.pp,1));
  const f_cpg=Math.ceil(cpg_tot/Math.max(carta.pg,1));
  const dorsi_da_scarto = f_cpe;
  const dorsi_mancanti = Math.max(0, cd_tot - dorsi_da_scarto);
  const cd_per_foglio = pezziPerFoglio(v('foglio_carta_l'), v('foglio_carta_h'), v('cd_l'), v('cd_h')).n;
  const f_cd_extra = dorsi_mancanti>0 ? Math.ceil(dorsi_mancanti/Math.max(cd_per_foglio,1)) : 0;
  const fogli_carta_tot = f_cpe + f_cpi + f_cpp + f_cpg + f_cd_extra;

  const fet = fettucciaPerCartella();
  const m_fettuccia = qty * fet.tot_complessivo / 100;
  const bobine = Math.ceil(m_fettuccia / Math.max(v('fettuccia_bob'),1));

  document.getElementById('tiles_riepilogo').innerHTML = `
    <div class="tile"><div class="l">Cartelle</div><div class="n">${qty}<span>pz</span></div></div>
    <div class="tile"><div class="l">Fogli cartone</div><div class="n">${fogli_cartone}<span>fg</span></div><div class="extra">${v('foglio_cartone_l')}×${v('foglio_cartone_h')} cm</div></div>
    <div class="tile"><div class="l">Rotoli tela</div><div class="n">${rotoli_tela}<span>rot</span></div><div class="extra">${m_tela_tot.toFixed(2)} m totali</div></div>
    <div class="tile"><div class="l">Fogli carta</div><div class="n">${fogli_carta_tot}<span>fg</span></div><div class="extra">${v('foglio_carta_l')}×${v('foglio_carta_h')} cm</div></div>
    <div class="tile accent" style="grid-column:span 2"><div class="l">Fettuccia totale</div><div class="n">${m_fettuccia.toFixed(2)}<span>metri</span></div><div class="extra">${bobine} bobina/e da ${v('fettuccia_bob')} m</div></div>
    <div class="tile accent" style="grid-column:span 2"><div class="l">Bobine necessarie</div><div class="n">${bobine}<span>bob</span></div><div class="extra">residuo: ${(bobine*v('fettuccia_bob') - m_fettuccia).toFixed(2)} m</div></div>
  `;

  document.getElementById('dettaglio_cartone').innerHTML = `
    <div class="row"><div class="k">Piatti necessari<small>2 per cartella</small></div><div class="v">${piatti_tot} pz</div></div>
    <div class="row"><div class="k">Dorsi necessari<small>1 per cartella</small></div><div class="v">${dorsi_tot} pz</div></div>
    <div class="row"><div class="k">Piatti per foglio</div><div class="v">${cart.piatti_per_foglio} pz</div></div>
    <div class="row"><div class="k">Dorsi per foglio</div><div class="v">${cart.dorsi_per_foglio} pz</div></div>
    <div class="row"><div class="k">Fogli per coprire i piatti</div><div class="v">${fogli_per_piatti} fg</div></div>
    <div class="row"><div class="k">Fogli per coprire i dorsi</div><div class="v">${fogli_per_dorsi} fg</div></div>
    <div class="row total"><div class="k">Fogli di cartone necessari<small>max tra i due — ${v('foglio_cartone_l')}×${v('foglio_cartone_h')} cm</small></div><div class="v">${fogli_cartone} fg</div></div>
    <div class="row"><div class="k">Sfrido piatti / dorsi</div><div class="v">${sfr_piatti} / ${sfr_dorsi} pz</div></div>
  `;

  document.getElementById('dettaglio_tela').innerHTML = `
    <div class="row"><div class="k">Dorso tela<small>${dt_tot} pz · ${tela.dt_per_fascia}/fascia</small></div><div class="v">${fasce_dt} fasce · ${m_dt.toFixed(2)} m</div></div>
    <div class="row"><div class="k">Patta piccola<small>${pp_tot} pz · ${tela.pp_per_fascia}/fascia</small></div><div class="v">${fasce_pp} fasce · ${m_pp.toFixed(2)} m</div></div>
    <div class="row"><div class="k">Patta grande<small>${pg_tot} pz · ${tela.pg_per_fascia}/fascia</small></div><div class="v">${fasce_pg} fasce · ${m_pg.toFixed(2)} m</div></div>
    <div class="row total"><div class="k">Totale tela necessaria<small>rotolo: ${v('tela_h')}×${v('tela_lung')} m</small></div><div class="v">${m_tela_tot.toFixed(2)} m</div></div>
    <div class="row"><div class="k">Rotoli da acquistare<small>residuo da rotolo: ${tela_residua.toFixed(2)} m</small></div><div class="v">${rotoli_tela} rot</div></div>
  `;

  document.getElementById('dettaglio_carta').innerHTML = `
    <div class="row"><div class="k">Piatti esterni<small>${cpe_tot} pz · ${carta.pe}/foglio</small></div><div class="v">${f_cpe} fg</div></div>
    <div class="row"><div class="k">Piatti interni<small>${cpi_tot} pz · ${carta.pi}/foglio</small></div><div class="v">${f_cpi} fg</div></div>
    <div class="row"><div class="k">Dorso carta<small>${cd_tot} pz · da scarto piatti esterni: ${dorsi_da_scarto}</small></div><div class="v">${f_cd_extra} fg extra</div></div>
    <div class="row"><div class="k">Carta patte piccole<small>${cpp_tot} pz · ${carta.pp}/foglio</small></div><div class="v">${f_cpp} fg</div></div>
    <div class="row"><div class="k">Carta patte grandi<small>${cpg_tot} pz · ${carta.pg}/foglio</small></div><div class="v">${f_cpg} fg</div></div>
    <div class="row total"><div class="k">Totale fogli di carta<small>${v('foglio_carta_l')}×${v('foglio_carta_h')} cm</small></div><div class="v">${fogli_carta_tot} fg</div></div>
  `;

  const m_d=(qty*fet.tot_dorso/100), m_c=(qty*fet.tot_cartella/100), m_p=(qty*fet.tot_patta/100);
  document.getElementById('dettaglio_fettuccia').innerHTML = `
    <div class="row"><div class="k">Fettuccia dorso<small>${v('fd_q')} × ${v('fd_l')} cm per cartella</small></div><div class="v">${m_d.toFixed(2)} m</div></div>
    <div class="row"><div class="k">Fettuccia cartella<small>${v('fc_q')} × ${v('fc_l')} cm per cartella</small></div><div class="v">${m_c.toFixed(2)} m</div></div>
    <div class="row"><div class="k">Fettuccia patta piccola<small>${v('fp_q')} × ${v('fp_l')} cm per cartella</small></div><div class="v">${m_p.toFixed(2)} m</div></div>
    <div class="row total"><div class="k">Totale fettuccia<small>bobina da ${v('fettuccia_bob')} m</small></div><div class="v">${m_fettuccia.toFixed(2)} m</div></div>
    <div class="row"><div class="k">Bobine necessarie</div><div class="v">${bobine} bob</div></div>
  `;

  window._lastCalc = {qty, fogli_cartone, m_tela_tot, rotoli_tela, fogli_carta_tot, m_fettuccia, bobine,
    cart, tela, carta, fet, dt_tot, pp_tot, pg_tot, cpe_tot, cpi_tot, cd_tot, cpp_tot, cpg_tot};
}

function aggiornaTutto(){
  layoutCartone();
  layoutTela();
  layoutCarta();
  fettucciaPerCartella();
  aggiornaProduzione();
}

document.querySelectorAll('.tab').forEach(t=>{
  t.addEventListener('click',()=>{
    document.querySelectorAll('.tab').forEach(x=>x.classList.remove('active'));
    document.querySelectorAll('.panel').forEach(x=>x.classList.remove('active'));
    t.classList.add('active');
    document.getElementById('tab-'+t.dataset.tab).classList.add('active');
    aggiornaTutto();
  });
});

FIELDS.forEach(id=>{
  const el=document.getElementById(id);
  if(el) el.addEventListener('input', aggiornaTutto);
});
document.getElementById('qty_cartelle').addEventListener('input', aggiornaProduzione);

/* ============================================================
   MODELLI — localStorage
   ============================================================ */
function caricaListaModelli(){
  const lista = document.getElementById('lista_modelli');
  let keys = [];
  try { keys = storage.list(); }
  catch(e){
    lista.innerHTML = `<div class="alert">Impossibile accedere allo storage del browser. I modelli non potranno essere salvati.</div>`;
    return;
  }
  if(keys.length===0){
    lista.innerHTML = `<div class="model-card"><div class="info"><div class="name">Nessun modello salvato</div><div class="meta">Salva la configurazione corrente dall'alto</div></div></div>`;
    return;
  }
  lista.innerHTML='';
  for(const k of keys){
    try{
      const m = JSON.parse(storage.get(k));
      const div=document.createElement('div');
      div.className='model-card';
      div.innerHTML = `
        <div class="info">
          <div class="name">${escapeHtml(m.name)}</div>
          <div class="meta">Piatto ${m.data.piatto_l}×${m.data.piatto_h} · Dorso ${m.data.dorso_l} cm · salvato ${m.date}</div>
        </div>
        <div class="actions">
          <button class="btn" onclick="caricaModello('${k}')">Carica</button>
          <button class="btn danger" onclick="eliminaModello('${k}')">✕</button>
        </div>`;
      lista.appendChild(div);
    }catch(e){}
  }
}

function escapeHtml(s){
  return String(s).replace(/[&<>"']/g, c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

function salvaModello(){
  const name = document.getElementById('new_model_name').value.trim();
  const a=document.getElementById('alert_save');
  if(!name){
    a.style.display='block';
    a.style.borderLeftColor='var(--warn)';
    a.textContent='⚠ Inserisci un nome per il modello prima di salvare';
    return;
  }
  const data={};
  FIELDS.forEach(id=>{ data[id]=v(id); });
  const key=STORAGE_PREFIX+name.toLowerCase().replace(/[^a-z0-9]+/g,'_').slice(0,50);
  const payload={name, data, date:new Date().toLocaleDateString('it-IT')};
  try{
    storage.set(key, JSON.stringify(payload));
    a.style.display='block';
    a.style.borderLeftColor='var(--ok)';
    a.textContent='✓ Modello "'+name+'" salvato';
    document.getElementById('new_model_name').value='';
    caricaListaModelli();
    setTimeout(()=>{a.style.display='none'},2500);
  }catch(e){
    a.style.display='block';
    a.style.borderLeftColor='var(--accent)';
    a.textContent='✕ Errore nel salvataggio: '+e.message;
  }
}

function caricaModello(key){
  try{
    const m=JSON.parse(storage.get(key));
    Object.entries(m.data).forEach(([id,val])=>{
      const el=document.getElementById(id);
      if(el) el.value=val;
    });
    document.getElementById('activeModelName').textContent='— '+m.name+' —';
    aggiornaTutto();
    document.querySelector('.tab[data-tab="misure"]').click();
  }catch(e){alert('Errore: '+e.message);}
}

function eliminaModello(key){
  if(!confirm('Eliminare questo modello?')) return;
  try{
    storage.delete(key);
    caricaListaModelli();
  }catch(e){alert('Errore: '+e.message);}
}

function esportaModelli(){
  const keys = storage.list();
  if(keys.length===0){ alert('Nessun modello da esportare.'); return; }
  const dump = {};
  keys.forEach(k=>{ dump[k] = JSON.parse(storage.get(k)); });
  const blob = new Blob([JSON.stringify(dump,null,2)],{type:'application/json'});
  const url=URL.createObjectURL(blob);
  const a=document.createElement('a');
  a.href=url; a.download=`modelli_faldoni_${new Date().toISOString().slice(0,10)}.json`; a.click();
  URL.revokeObjectURL(url);
}

function importaModelli(event){
  const file = event.target.files[0];
  if(!file) return;
  const reader = new FileReader();
  reader.onload = (e)=>{
    try{
      const dump = JSON.parse(e.target.result);
      let count=0;
      Object.entries(dump).forEach(([k,v])=>{
        if(k.startsWith(STORAGE_PREFIX) && v.name && v.data){
          storage.set(k, JSON.stringify(v));
          count++;
        }
      });
      alert(`Importati ${count} modelli.`);
      caricaListaModelli();
    }catch(err){
      alert('File non valido: '+err.message);
    }
  };
  reader.readAsText(file);
  event.target.value='';
}

